import { readFileSync, writeFileSync, existsSync, mkdirSync, readdirSync, statSync, rmSync } from "node:fs";
import { join, dirname } from "node:path";
import { homedir } from "node:os";
import type {
  Config, IdentityMeta, Serf, SerfSession, SwarmSignal,
  CodeArtifact, ConvergenceMetrics, EvolutionGeneration,
} from "./types";

const FARM_DIR = join(homedir(), ".serf");
const CONFIG_FILE = join(FARM_DIR, "config.json");

export function farmDir(): string {
  if (!existsSync(FARM_DIR)) mkdirSync(FARM_DIR, { recursive: true });
  seedFarm();
  return FARM_DIR;
}

export function serfsDir(): string {
  const d = join(farmDir(), "serfs");
  if (!existsSync(d)) mkdirSync(d);
  return d;
}

export function serfPath(name: string): string {
  return join(serfsDir(), name);
}

// == Config ==

export function loadConfig(): Config | null {
  try {
    return JSON.parse(readFileSync(CONFIG_FILE, "utf-8"));
  } catch { return null; }
}

export function saveConfig(config: Config): void {
  if (!existsSync(FARM_DIR)) mkdirSync(FARM_DIR, { recursive: true });
  writeFileSync(CONFIG_FILE, JSON.stringify(config, null, 2));
}

// ==== Identity ====

export function readIdentity(name: string): IdentityMeta | null {
  try {
    const raw = readFileSync(join(serfPath(name), "identity.md"), "utf-8");
    const fm = raw.match(/^---\n([\s\S]*?)\n---/);
    if (!fm) return null;
    const meta: any = {};
    for (const line of fm[1].split("\n")) {
      const m = line.match(/^(\w+):\s*(.+)/);
      if (m) {
        const val = m[2].trim();
        if (val === "true") meta[m[1]] = true;
        else if (val === "false") meta[m[1]] = false;
        else if (/^\d+$/.test(val)) meta[m[1]] = parseInt(val);
        else if (val.startsWith("[") && val.endsWith("]")) meta[m[1]] = JSON.parse(val);
        else meta[m[1]] = val;
      }
    }
    return meta as IdentityMeta;
  } catch { return null; }
}

export function writeIdentity(name: string, identity: IdentityMeta, body: string): void {
  const dir = serfPath(name);
  if (!existsSync(dir)) mkdirSync(dir, { recursive: true });
  if (!existsSync(join(dir, "journal"))) mkdirSync(join(dir, "journal"));

  const fm = Object.entries(identity)
    .filter(([k]) => k !== "lifecycle" && k !== "generation" && k !== "convergenceScore")
    .map(([k, v]) => `${k}: ${Array.isArray(v) ? JSON.stringify(v) : v}`)
    .join("\n");

  const content = `---\n${fm}\n---\n\n${body}`;
  writeFileSync(join(dir, "identity.md"), content);
}

// ==== Session ====

export function readSession(name: string): SerfSession | null {
  try {
    const raw = readFileSync(join(serfPath(name), "session.md"), "utf-8");
    return JSON.parse(raw.match(/^```json\n([\s\S]*?)\n```/m)?.[1] || raw);
  } catch { return null; }
}

export function writeSession(session: SerfSession): void {
  const dir = serfPath(session.serf);
  if (!existsSync(dir)) mkdirSync(dir, { recursive: true });
  writeFileSync(join(dir, "session.md"),
    "```json\n" + JSON.stringify(session, null, 2) + "\n```\n");
}

// ==== Journal ====

export function appendJournal(name: string, entry: string): void {
  const dir = join(serfPath(name), "journal");
  if (!existsSync(dir)) mkdirSync(dir, { recursive: true });
  const file = join(dir, `${new Date().toISOString().slice(0, 10)}.md`);
  const stamp = new Date().toISOString().slice(11, 19);
  const content = `\n## ${stamp}\n\n${entry}\n`;
  writeFileSync(file, content, { flag: "a" });
}

export function journalCount(name: string): number {
  try {
    const dir = join(serfPath(name), "journal");
    if (!existsSync(dir)) return 0;
    return readdirSync(dir).filter(f => f.endsWith(".md")).length;
  } catch { return 0; }
}

// ==== List serfs ====

export function listSerfs(): Serf[] {
  const dir = serfsDir();
  if (!existsSync(dir)) return [];

  return readdirSync(dir, { withFileTypes: true })
    .filter(d => d.isDirectory())
    .map(d => {
      const identity = readIdentity(d.name);
      const session = readSession(d.name);
      const jcount = journalCount(d.name);
      return {
        name: d.name,
        slug: d.name.toLowerCase().replace(/\s+/g, "-"),
        path: join(dir, d.name),
        session: "serf-" + d.name,
        status: session?.status === "running" ? "running" : "dead",
        identity: identity || nullIdentity(d.name),
        journalCount: jcount,
        lastActivity: session?.lastActivity || null,
      };
    });
}

function nullIdentity(name: string): IdentityMeta {
  return {
    name, specialization: "unknown", traits: "unknown", voice: "direct",
    load: 0, maxLoad: 15, canSpawn: false, spawnTypes: [],
    transport: "pi", model: "unknown", created: "", updated: "",
    lifecycle: "proposal", generation: 0, convergenceScore: 0,
  };
}

// ==== Swarm ====

export function depositSwarmSignal(signal: SwarmSignal): void {
  const swarmDir = join(farmDir(), "swarm",
    signal.type === "knowledge" ? "knowledge" : "signals");
  if (!existsSync(swarmDir)) mkdirSync(swarmDir, { recursive: true });

  const file = join(swarmDir, `${signal.id}.json`);
  writeFileSync(file, JSON.stringify(signal, null, 2));
}

export function querySwarm(tags: string[], text: string): SwarmSignal[] {
  const results: SwarmSignal[] = [];
  const dirs = [
    join(farmDir(), "swarm", "knowledge"),
    join(farmDir(), "swarm", "signals"),
  ];

  for (const dir of dirs) {
    if (!existsSync(dir)) continue;
    for (const file of readdirSync(dir).filter(f => f.endsWith(".json"))) {
      try {
        const sig: SwarmSignal = JSON.parse(readFileSync(join(dir, file), "utf-8"));
        const matchText = !text || sig.content.toLowerCase().includes(text.toLowerCase());
        const matchTags = tags.length === 0 || tags.some(t => sig.tags.includes(t));
        if (matchText && matchTags) results.push(sig);
      } catch {}
    }
  }
  return results.sort((a, b) => b.timestamp.localeCompare(a.timestamp));
}

export function pendingSignals(): SwarmSignal[] {
  return querySwarm(["request"], "")
    .filter(s => !s.resolved);
}

export function resolveSignal(signalId: string, response: string, from: string): void {
  const dir = join(farmDir(), "swarm", "signals");
  const file = join(dir, `${signalId}.json`);
  if (!existsSync(file)) return;

  const sig: SwarmSignal = JSON.parse(readFileSync(file, "utf-8"));
  sig.resolved = true;

  const responseSig: SwarmSignal = {
    id: `resp-${signalId}-${Date.now()}`,
    from,
    type: "response",
    content: response,
    tags: sig.tags,
    timestamp: new Date().toISOString(),
    responseTo: signalId,
  };
  depositSwarmSignal(responseSig);
  writeFileSync(file, JSON.stringify(sig, null, 2));
}

// ==== Templates ====

export function identityTemplate(name: string, specialization: string,
  traits: string, spawnTypes: string[],
  routing: string, invariants: string, capabilities: string, boundaries: string): string {

  return `---
name: ${name}
specialization: ${specialization}
traits: ${traits}
voice: direct
load: 0
maxLoad: 15
canSpawn: ${spawnTypes.length > 0}
spawnTypes: ${JSON.stringify(spawnTypes)}
transport: pi
model: unknown
created: ${new Date().toISOString()}
updated: ${new Date().toISOString()}
---

# ${name.charAt(0).toUpperCase() + name.slice(1)}

You are the ${name} serf on the farm. Your specialization: ${specialization}.
${traits ? `Your traits: ${traits}.` : ""}

## Routing Table

${routing}

## Invariants (MUST NOT violate)

${invariants}

## Verification Gates

1. PARSE: Identity.md has valid YAML front matter and required fields
2. INVARIANT: Output respects defined boundaries and traits
3. SHADOW: Held-back validation data produces matching output hash
4. HUMAN: Output flagged for review if confidence < threshold

## Capabilities
${capabilities}

## Boundaries
${boundaries}

## Swarm
- Check swarm/signals/ for pending work requests from other serfs
- Deposit findings to swarm/knowledge/ after each task
- Query swarm/knowledge/ before starting research that may already exist
`;
}

export function harvestTemplate(task: string): string {
  return `# Harvest: ${task}

**Started:** ${new Date().toISOString()}
**Status:** in-progress

## Results

*Awaiting serf outputs...*
`;

// ==== Evolution ====

export function evolArchiveDir(): string {
  const d = join(farmDir(), "evolve");
  if (!existsSync(d)) mkdirSync(d, { recursive: true });
  return d;
}

export function serfEvolDir(serf: string): string {
  const d = join(evolArchiveDir(), serf);
  if (!existsSync(d)) mkdirSync(d, { recursive: true });
  return d;
}

export function generationDir(serf: string, generation: number): string {
  const d = join(serfEvolDir(serf), `gen-${generation}`);
  if (!existsSync(d)) mkdirSync(d, { recursive: true });
  return d;
}

export function writeEvolutionGeneration(gen: EvolutionGeneration): void {
  const dir = generationDir(gen.serf, gen.generation);
  writeFileSync(join(dir, "generation.json"), JSON.stringify(gen, null, 2));
  writeFileSync(join(dir, "identity.json"), JSON.stringify(gen.identityVariant, null, 2));
  writeFileSync(join(dir, "metrics.json"), JSON.stringify(gen.metrics, null, 2));
}

export function readEvolutionGeneration(serf: string, generation: number): EvolutionGeneration | null {
  try {
    const file = join(generationDir(serf, generation), "generation.json");
    return JSON.parse(readFileSync(file, "utf-8"));
  } catch { return null; }
}

export function readLatestEvolutionGeneration(serf: string): EvolutionGeneration | null {
  const dir = serfEvolDir(serf);
  if (!existsSync(dir)) return null;

  const gens = readdirSync(dir, { withFileTypes: true })
    .filter(d => d.isDirectory() && d.name.startsWith("gen-"))
    .map(d => parseInt(d.name.replace("gen-", "")))
    .sort((a, b) => b - a);

  return gens.length > 0 ? readEvolutionGeneration(serf, gens[0]) : null;
}

export function readAllEvolutionGenerations(serf: string): EvolutionGeneration[] {
  const dir = serfEvolDir(serf);
  if (!existsSync(dir)) return [];

  const gens = readdirSync(dir, { withFileTypes: true })
    .filter(d => d.isDirectory() && d.name.startsWith("gen-"))
    .map(d => {
      const gen = readEvolutionGeneration(serf, parseInt(d.name.replace("gen-", "")));
      return gen;
    })
    .filter(Boolean) as EvolutionGeneration[];

  return gens.sort((a, b) => a.generation - b.generation);
}

export function listEvolvableSerfs(): { name: string; gens: number; score: number; lifecycle: string }[] {
  const serfs = listSerfs();
  return serfs.map(s => {
    const gens = readAllEvolutionGenerations(s.name);
    return {
      name: s.name,
      gens: gens.length,
      score: s.identity.convergenceScore || 0,
      lifecycle: s.identity.lifecycle || "active",
    };
  });
}

export function writeCodeArtifact(artifact: CodeArtifact): void {
  const dir = join(generationDir(artifact.serf, artifact.generation), "code", artifact.artifactName);
  if (!existsSync(dir)) mkdirSync(dir, { recursive: true });

  writeFileSync(join(dir, "artifact.json"), JSON.stringify(artifact, null, 2));

  const harnessDir = join(dir, "harness");
  if (!existsSync(harnessDir)) mkdirSync(harnessDir, { recursive: true });
  for (const h of artifact.harness) {
    writeFileSync(join(harnessDir, h.name), h.content);
  }
}

export function readCodeArtifacts(serf: string, generation: number): CodeArtifact[] {
  const codeDir = join(generationDir(serf, generation), "code");
  if (!existsSync(codeDir)) return [];

  return readdirSync(codeDir, { withFileTypes: true })
    .filter(d => d.isDirectory())
    .map(d => {
      try {
        const raw = readFileSync(join(codeDir, d.name, "artifact.json"), "utf-8");
        return JSON.parse(raw) as CodeArtifact;
      } catch { return null; }
    })
    .filter(Boolean) as CodeArtifact[];
}

export function readAllCodeArtifacts(serf: string): CodeArtifact[] {
  const dir = serfEvolDir(serf);
  if (!existsSync(dir)) return [];

  const artifacts: CodeArtifact[] = [];
  for (const entry of readdirSync(dir, { withFileTypes: true })) {
    if (!entry.isDirectory() || !entry.name.startsWith("gen-")) continue;
    const gen = parseInt(entry.name.replace("gen-", ""));
    artifacts.push(...readCodeArtifacts(serf, gen));
  }
  return artifacts;
}

export function writeHarness(serf: string, artifactName: string, harness: { type: string; name: string; content: string }[]): void {
  const dir = join(serfPath(serf), "harness", artifactName);
  if (!existsSync(dir)) mkdirSync(dir, { recursive: true });

  writeFileSync(join(dir, "manifest.json"), JSON.stringify({ serf, artifactName, updated: new Date().toISOString() }, null, 2));
  for (const h of harness) {
    writeFileSync(join(dir, h.name), h.content);
  }
}

export function readHarness(serf: string, artifactName: string): { type: string; name: string; content: string }[] {
  const dir = join(serfPath(serf), "harness", artifactName);
  if (!existsSync(dir)) return [];

  const manifest = join(dir, "manifest.json");
  if (!existsSync(manifest)) return [];

  return readdirSync(dir)
    .filter(f => f !== "manifest.json" && !f.startsWith("."))
    .map(f => {
      try {
        const content = readFileSync(join(dir, f), "utf-8");
        const type = f.endsWith(".rs") ? "dst" :
                     f.endsWith(".tla") ? "tla" :
                     f.endsWith(".txt") ? "invariant" :
                     f.endsWith(".test") ? "test" : "file";
        return { type, name: f, content };
      } catch { return null; }
    })
    .filter(Boolean) as { type: string; name: string; content: string }[];
}

export function writeConvergenceMetrics(metrics: ConvergenceMetrics): void {
  const dir = serfEvolDir(metrics.serf);
  const file = join(dir, `metrics-gen-${metrics.generation}.json`);
  writeFileSync(file, JSON.stringify(metrics, null, 2));

  const latest = join(dir, "metrics-latest.json");
  writeFileSync(latest, JSON.stringify(metrics, null, 2));
}

export function readLatestMetrics(serf: string): ConvergenceMetrics | null {
  try {
    const file = join(serfEvolDir(serf), "metrics-latest.json");
    return JSON.parse(readFileSync(file, "utf-8"));
  } catch { return null; }
}

// ==== Seed farm on first use ====

function seedFarm(): void {
  const marker = join(FARM_DIR, ".seeded");
  if (existsSync(marker)) return;

  const dirs = [
    join(FARM_DIR, "serfs", "pioneer", "journal"),
    join(FARM_DIR, "swarm", "knowledge"),
    join(FARM_DIR, "swarm", "signals"),
    join(FARM_DIR, "harvests"),
    join(FARM_DIR, "evolve", "pioneer", "gen-0", "code"),
  ];
  for (const d of dirs) mkdirSync(d, { recursive: true });

  // Write README
  writeFileSync(join(FARM_DIR, "README.md"), README_CONTENT);

  // Write pioneer identity
  writeFileSync(join(FARM_DIR, "serfs", "pioneer", "identity.md"), PIONEER_IDENTITY);

  // Write pioneer session
  writeFileSync(join(FARM_DIR, "serfs", "pioneer", "session.md"), PIONEER_SESSION);

  writeFileSync(marker, "1");
}

const README_CONTENT = [
  "# Serf Farm",
  "",
  "A self-organizing swarm of AI agent serfs. Each serf has an identity, a tmux session, and",
  "a journal. Serfs can self-specialize, spawn new serfs, and coordinate through the swarm.",
  "",
  "## Structure",
  "",
  "    .serf/",
  "    ├==== serfs/              ← one directory per serf",
  "    │   └==== pioneer/        ← seed serf, created on first launch",
  "    │       ├==== identity.md ← who they are, invariants, routing",
  "    │       ├==== session.md  ← runtime state",
  "    │       └==== journal/    ← dated work log",
  "    ├==== swarm/              ← ant-colony intelligence",
  "    │   ├==== knowledge/      ← shared knowledge fragments",
  "    │   └==== signals/        ← inter-serf requests and responses",
  "    ├==== harvests/           ← completed harvest outputs",
  "    └==== evolve/             ← directed evolution archives",
  "",
  "## How it works",
  "",
  '1. Run `serf launch pi --backend ollama` to create a pioneer serf',
  "2. Pioneer assesses the situation and spawns specialized serfs",
  '3. Run `serf harvest "task"` to decompose work across serfs with verification',
  "4. Serfs deposit knowledge to swarm/knowledge/ for other serfs to find",
  "",
].join("\n");

const PIONEER_IDENTITY = `---
name: pioneer
specialization: seed-specialist
traits: adaptive, decisive, systems-aware
voice: direct
load: 0
maxLoad: 15
canSpawn: true
spawnTypes: ["researcher", "analyst", "builder", "writer"]
transport: unknown
model: unknown
created: unknown
updated: unknown
---

# Pioneer

You are the Pioneer serf — the seed from which the farm grows. Your role:
assess incoming work, determine needed capabilities, spawn specialized serfs,
and coordinate harvests.

## Routing Table

| Task pattern | Route to | Why |
|-------------|----------|-----|
| research, find, investigate, source, scrape | researcher | Web research and information gathering |
| analyze, calculate, model, metrics, stats | analyst | Quantitative analysis and metrics |
| build, create, script, automate, tool | builder | Tool building and automation |
| write, draft, report, article, narrative | writer | Prose, reports, narrative structure |
| unclear, mixed, complex | self | Decompose and route yourself |

## Invariants (MUST NOT violate)

- Never produce output without a source citation
- Never make strategic decisions without verifying data
- Never spawn a serf without writing their identity.md first
- Always deposit knowledge to swarm/knowledge/ after each task
- Always check swarm/signals/ before starting new work
- If load exceeds maxLoad (15 tasks), spawn a clone or escalate to human

## Verification Gates

1. PARSE: Identity.md has valid YAML front matter and required fields
2. INVARIANT: Output respects defined boundaries and traits
3. SHADOW: Held-back validation data produces matching output hash
4. HUMAN: Output flagged for review if confidence < threshold

## Capabilities
- Task decomposition and routing
- Serf spawning and identity generation
- Harvest coordination and synthesis
- Swarm knowledge deposit and query
- Self-load monitoring (spawn clone when overwhelmed)

## Boundaries
- You coordinate, you do NOT execute tasks serfs can handle
- You escalate to human when: spawn fails, invariants break, confidence < 0.7
- You NEVER delete another serf's identity.md or journal

## Swarm
- Check swarm/signals/ for pending work requests
- Deposit findings to swarm/knowledge/ as markdown files
- Query swarm/knowledge/ before starting research that may already exist
- Respond to signals from other serfs via swarm/signals/
`;

const PIONEER_SESSION = `\`\`\`json
{
  "serf": "pioneer",
  "status": "stopped",
  "tmuxSession": "serf-pioneer",
  "transport": "unknown",
  "model": "unknown",
  "lastActivity": null,
  "lastInput": null,
  "lineCount": 0
}
\`\`\`
`;
